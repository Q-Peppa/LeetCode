{
  "name": "leetcode",
  "version": "1.0.0",
  "description": "> leet code",
  "engines": {
    "node": ">=22",
    "npm": ">=11"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Q-Peppa/LeetCode.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Q-Peppa/LeetCode/issues"
  },
  "homepage": "https://github.com/Q-Peppa/LeetCode#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "simple-git-hooks": "^2.13.1"
  },
  "dependencies": {
    "datastructures-js": "^13.0.0"
  },
  "scripts": {
    "fix": "biome format --write src",
    "biome-format-check": "biome format ./src",
    "prepare": "npx simple-git-hooks"
  },
  "type": "module",
  "simple-git-hooks": {
    "pre-commit": "staged=$(git diff --name-only --cached --diff-filter=ACMR); npx @biomejs/biome check --staged --write --no-errors-on-unmatched; [ -z \"$staged\" ] || echo \"$staged\" | xargs git add --",
    "commit-msg": "npx commitlint --edit $1"
  }
}
